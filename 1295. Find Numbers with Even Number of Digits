1 .first i thinked about how i will count each numbers digit 
2 .so i divide each number by 10 
3 .so i get there are n numbers 
4. if that numbers are divisible by 2 then they are even either odd


Solution:

class Solution {
public:
    int findNumbers(vector<int>& nums) {
        int count = 0;

        for(int i= 0; i < nums.size();i++){
            int n = 0;
            while(nums[i]!=0){
                nums[i]/=10;
                n++;
            }
            if(n%2==0){
                count++;
            }
        }
        return count;
        
    }
};
